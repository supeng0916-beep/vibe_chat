# Copy to .env and fill local secrets. Never commit real keys.

# ── LLM 接口选择：openai | anthropic（改这一行即可切换双标准，需重启后端）──
LLM_PROVIDER=openai

# ── OpenAI 标准接口（base_url 可指向任意 OpenAI 兼容网关）──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic 标准接口（base_url 留默认走官方；可指向兼容 /v1/messages 的网关）──
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-haiku-4-5

# ── 其它 ──
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=sqlite:///./vibechat.db
MATCH_TIMEOUT_SECONDS=15

# ── 前端 ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
